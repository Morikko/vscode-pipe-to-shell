{
  "name": "pipe-to-shell",
  "displayName": "Pipe to Shell",
  "description": "Leverage your favourite shell commands to edit text",
  "version": "0.1.0-beta.2",
  "publisher": "morikko",
  "license": "SEE LICENSE IN LICENSE.txt",
  "icon": "images/pipe-to-shell-v2.png",
  "bugs": {
    "url": "https://github.com/morikko/vscode-pipe-to-shell/issues"
  },
  "homepage": "https://github.com/morikko/vscode-pipe-to-shell/blob/master/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/morikko/vscode-pipe-to-shell.git"
  },
  "engines": {
    "vscode": "^1.26.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "shell",
    "command",
    "filter"
  ],
  "activationEvents": [
    "onCommand:pipeToShell.clearCommandHistory",
    "onCommand:pipeToShell.runCommandInPlace",
    "onCommand:pipeToShell.runCommandNewEditor",
    "onCommand:pipeToShell.quickCommand"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pipeToShell.clearCommandHistory",
        "title": "Clear command history",
        "category": "PipeToShell"
      },
      {
        "command": "pipeToShell.runCommandInPlace",
        "title": "Run command in-place",
        "category": "PipeToShell"
      },
      {
        "command": "pipeToShell.runCommandNewEditor",
        "title": "Run command to new editor",
        "category": "PipeToShell"
      }
    ],
    "keybindings": [
      {
        "command": "pipeToShell.CommandReaderToggleNewEditor",
        "key": "ctrl+n",
        "when": "pipeToShell.CommandReaderOpen"
      },
      {
        "command": "pipeToShell.CommandReaderToggleSaveHistory",
        "key": "ctrl+s",
        "when": "pipeToShell.CommandReaderOpen"
      },
      {
        "command": "pipeToShell.CommandReaderToggleShowFavorite",
        "key": "ctrl+f",
        "when": "pipeToShell.CommandReaderOpen"
      },
      {
        "command": "pipeToShell.CommandReaderToggleShowHistory",
        "key": "ctrl+h",
        "when": "pipeToShell.CommandReaderOpen"
      },
      {
        "command": "pipeToShell.CommandReaderToggleProcessEntireText",
        "key": "ctrl+g",
        "when": "pipeToShell.CommandReaderOpen"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Pipe to Shell configurations",
      "properties": {
        "pipeToShell.currentDirectoryKind": {
          "description": "Current directory for shell commands",
          "type": "string",
          "enum": [
            "currentFile",
            "workspaceRoot"
          ],
          "default": "currentFile"
        },
        "pipeToShell.favoriteCommands": {
          "description": "Favorite commands always shown in the suggestion and assignable to keybindings.",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "It can be assigned to a keybinding for quick execution"
              },
              "command": {
                "type": "string"
              },
              "name": {
                "type": "string",
                "description": "A more human friendly name to show in the suggestion"
              }
            },
            "required": [
              "id",
              "command"
            ]
          },
          "default": []
        },
        "pipeToShell.processEntireTextIfNoneSelected": {
          "description": "Pipe the entire text to the shell command if no text is selected",
          "type": "boolean",
          "default": false
        },
        "pipeToShell.shell.linux": {
          "description": "The path of the shell that this extension uses on Linux",
          "type": "string",
          "default": "/bin/sh"
        },
        "pipeToShell.shellArgs.linux": {
          "description": "Arguments to the shell to be used on Linux",
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "-c"
          ]
        },
        "pipeToShell.shell.osx": {
          "description": "The path of the shell that this extension uses on OS X",
          "type": "string",
          "default": "/bin/sh"
        },
        "pipeToShell.shellArgs.osx": {
          "description": "Arguments to the shell to be used on OS X",
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "-c"
          ]
        },
        "pipeToShell.shell.windows": {
          "description": "The path of the shell that this extension uses on Windows",
          "type": "string",
          "default": "cmd.exe"
        },
        "pipeToShell.shellArgs.windows": {
          "description": "Arguments to the shell to be used on Windows",
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "/d",
            "/s",
            "/c"
          ]
        },
        "pipeToShell.shell.env": {
          "description": "An object where the key is a environment variable name and the value its value",
          "type": "object",
          "default": {}
        },
        "pipeToShell.historyMaxSize": {
          "description": "The number of executed commands save",
          "type": "integer",
          "default": 100
        },
        "pipeToShell.logging.success.command": {
          "type": "boolean",
          "default": true
        },
        "pipeToShell.logging.success.stdin": {
          "type": "boolean",
          "default": false
        },
        "pipeToShell.logging.success.stdout": {
          "type": "boolean",
          "default": false
        },
        "pipeToShell.logging.success.stderr": {
          "type": "boolean",
          "default": true
        },
        "pipeToShell.logging.success.env": {
          "type": "boolean",
          "default": false
        },
        "pipeToShell.logging.success.cwd": {
          "type": "boolean",
          "default": false
        },
        "pipeToShell.logging.failure.command": {
          "type": "boolean",
          "default": true
        },
        "pipeToShell.logging.failure.stdin": {
          "type": "boolean",
          "default": false
        },
        "pipeToShell.logging.failure.stdout": {
          "type": "boolean",
          "default": true
        },
        "pipeToShell.logging.failure.stderr": {
          "type": "boolean",
          "default": true
        },
        "pipeToShell.logging.failure.env": {
          "type": "boolean",
          "default": false
        },
        "pipeToShell.logging.failure.cwd": {
          "type": "boolean",
          "default": true
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint src/ --format unix --ext .ts",
    "lint:fix": "eslint src/ --format unix --ext .ts --fix",
    "test": "vscode-test",
    "test:coverage": "vscode-test --coverage",
    "test:watch": "vscode-test --watch",
    "compile": "tsc -p ./",
    "compile:watch": "tsc -watch -p ./",
    "prep": "npm run lint && npm run compile && npm test",
    "vscode:prepublish": "npm run compile",
    "vscode:postpublish": "./tag-release.sh",
    "build": "npx vsce package",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^12.14.1",
    "@types/source-map-support": "^0.5.10",
    "@types/vscode": "^1.26.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "3.9.1",
    "eslint": "^10.1.0",
    "eslint-formatter-unix": "^9.0.1",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "testdouble": "^3.13.1",
    "ts-node": "^9.0.0",
    "typescript": "^4.9.5",
    "typescript-eslint": "^8.58.0"
  },
  "resolutions": {
    "**/minimist": "^1.2.5"
  }
}
